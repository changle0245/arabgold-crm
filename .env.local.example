# ============================================================
# ArabGold CRM · 环境变量样板
# ------------------------------------------------------------
# 用法:
#   cp .env.local.example .env.local
# 然后把下面 < ... > 占位符替换成真值。.env.local 不入库。
# 真实 secret 一律从 1Password / Bitwarden 取,不要回填到这里。
# ============================================================

# ── Supabase(项目原有)─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-project-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── 入站邮件 webhook token(可选)──────────────────────────
INBOUND_EMAIL_TOKEN=<random-token-for-inbound-webhook>

# ── 自动翻译(可选)─────────────────────────────────────────
# 未配置时 translator 返回 null,聊天导入不会失败
TRANSLATION_PROVIDER=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# ── ArabGold 中台契约 v1.0 接入 ─────────────────────────────
# 必填两项 — 缺失时 /api/middleground/v1/* 全部返回 401 E_AUTH_FAILED
#
# MIDDLEGROUND_SITE_ID 由常乐分配,本站固定为 crm-arabgold
MIDDLEGROUND_SITE_ID=crm-arabgold
#
# MIDDLEGROUND_HMAC_SECRET 从 1Password 条目 middleground-crm-arabgold-hmac
# 字段 `secret` 取(64 字符 hex)。严禁经聊天工具传递。
MIDDLEGROUND_HMAC_SECRET=<32+-char-secret-from-password-manager>

# NextAuth (Auth.js v5) — Phase 2 added 2026-05-27
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Neon DATABASE_URL — Phase 1 / 3a port to Neon `crm-arabgold` project
# Use the pooled connection string (`-pooler.<region>.aws.neon.tech`).
# Direct URL only required for migrations / seed scripts.
DATABASE_URL=<neon-pooler-connection-string>

# Cloudflare R2 (via ArabGold Worker proxy) — Phase 4 added 2026-05-27
# All CRM objects are namespaced under the `crm-arabgold/` prefix.
R2_WORKER_URL=https://mute-hat-decearabgold-r2-proxy.5429752.workers.dev
R2_PUBLIC_URL=https://pub-441a56c753c24e5898ada9e2d91b41b1.r2.dev
R2_ADMIN_TOKEN=<ag_r2_*-token-from-password-manager>

# Inbound email webhook — already declared above; leave INBOUND_EMAIL_TOKEN
# blank to disable the queue endpoint in production.
